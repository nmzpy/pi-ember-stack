{
	"$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"includes": ["plugins/**/*.ts", "!**/node_modules/**", "!**/dist/**", "!plugins/**/test/**", "!plugins/pi-web-access/*.ts"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 100
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended",
			"style": {
				"useNamingConvention": "off"
			},
			"suspicious": {
				"noExplicitAny": "warn",
				"noControlCharactersInRegex": "off"
			},
			"complexity": {
				"noBannedTypes": "warn"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "always",
			"trailingCommas": "all"
		}
	}
}
