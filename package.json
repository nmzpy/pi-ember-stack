{
  "name": "@nmzpy/pi-ember-stack",
  "version": "0.2.4",
  "description": "Ember's configurable Pi stack with modes, compact tools, subagents, and Devin, Cursor, and xAI providers",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "pi-package",
    "pi-extension",
    "ember"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nmzpy/pi-ember-stack.git"
  },
  "bugs": {
    "url": "https://github.com/nmzpy/pi-ember-stack/issues"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome lint",
    "format": "biome format --write",
    "check": "biome check"
  },
  "files": [
    "README.md",
    "ATTRIBUTION.md",
    "tsconfig.json",
    "plugins"
  ],
  "exports": {
    ".": "./plugins/index.ts",
    "./renderer": "./plugins/pi-compact-tools/renderer.ts"
  },
  "pi": {
    "extensions": [
      "./plugins/index.ts"
    ]
  },
  "dependencies": {
    "@ff-labs/fff-node": "0.9.6",
    "@mozilla/readability": "^0.6.0",
    "@sinclair/typebox": "^0.34.0",
    "chalk": "^5.6.2",
    "linkedom": "^0.16.0",
    "p-limit": "^6.1.0",
    "turndown": "^7.2.0",
    "unpdf": "^1.6.2"
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@earendil-works/pi-agent-core": "^0.80.6",
    "@earendil-works/pi-ai": "^0.80.6",
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "@earendil-works/pi-tui": "^0.80.6",
    "@ff-labs/fff-node": "0.9.6",
    "@sinclair/typebox": "^0.34.0",
    "@types/node": "^20.19.43",
    "typebox": "^1.3.1",
    "typescript": "^5.9.3"
  }
}
